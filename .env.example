# Community Management environment configuration.
# Copy to .env and fill in. .env is gitignored; this file is committed.
# Week 1 runs fully on the CSV + fixtures path. No key below is required to
# bring the stack up or to import a CSV. Platform and LLM keys are only read
# when their connector or the generation layer is actually reached.

# --- Core infrastructure ---
DATABASE_URL=postgresql+psycopg://community_management:community_management@db:5432/community_management
REDIS_URL=redis://redis:6379/0
API_KEY=change-me
TZ_DISPLAY=Africa/Tunis
LOG_LEVEL=INFO
# Comma-separated origins allowed by CORS. Lock to the dashboard origin in prod.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Free LLM providers (all no-credit-card). Used from Week 6 on. ---
GROQ_API_KEY=
GOOGLE_API_KEY=            # aistudio.google.com
OPENROUTER_API_KEY=
NVIDIA_API_KEY=           # build.nvidia.com
OLLAMA_BASE_URL=http://host.docker.internal:11434   # optional local fallback
LLM_PRIMARY=groq/llama-3.3-70b-versatile
LLM_LONGCTX=gemini/gemini-2.5-flash

# --- Platform connectors. Used from Week 3 on. ---
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
YOUTUBE_API_KEY=

# --- Experiment tracking. Used from Week 4 on. ---
MLFLOW_TRACKING_URI=file:./mlruns
